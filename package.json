{
  "name": "onboard-plugin",
  "version": "0.1.0",
  "description": "Interactive project onboarding for AI coding agents. Generates CLAUDE.md, SPEC.md, TASKS.md through structured interviews.",
  "keywords": [
    "claude-code",
    "opencode",
    "ai-coding",
    "project-setup",
    "onboarding",
    "specification",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "tomg55555",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomg55555/onboard-plugin.git"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./install": "./dist/install.js",
    "./detect": "./dist/detect.js",
    "./validate": "./dist/validate.js"
  },
  "bin": {
    "onboard-plugin": "dist/bin/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/cli.ts",
    "test": "vitest",
    "lint": "eslint src/ bin/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/install.ts",
      "src/detect.ts",
      "src/validate.ts",
      "bin/cli.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "outDir": "dist"
  }
}
